# MongoDB Atlas Connection String
# Get this from https://cloud.mongodb.com
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/kphost?retryWrites=true&w=majority

# VirusTotal API Key for Malware Inspection
# Get free API key from https://www.virustotal.com
VIRUSTOTAL_API_KEY=YOUR_VIRUSTOTAL_API_KEY_HERE

# Discord OAuth2 Credentials
# Get from https://discord.com/developers/applications
DISCORD_CLIENT_ID=YOUR_DISCORD_CLIENT_ID
DISCORD_CLIENT_SECRET=YOUR_DISCORD_CLIENT_SECRET

# Google OAuth2 Credentials
# Get from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# GitHub OAuth Credentials
# Get from https://github.com/settings/developers
GITHUB_CLIENT_ID=YOUR_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET

# JWT & Application Secret
JWT_SECRET=kp_host_super_secret_jwt_key_2026
PORT=3000
